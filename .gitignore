# ============================================================
# Dependencies
# ============================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================================================
# Next.js build output
# ============================================================
/.next/
/out/
/build

# ============================================================
# Environment & secrets  (never commit secrets)
# ============================================================
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local

# ============================================================
# Testing / coverage
# ============================================================
/coverage

# ============================================================
# Debug logs
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ============================================================
# Binary & media files (keep repo under 1 MB)
# ============================================================
# Images
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.svg
*.webp
*.avif
*.bmp
*.tif
*.tiff

# Fonts
*.woff
*.woff2
*.ttf
*.otf
*.eot

# Audio / Video
*.mp3
*.mp4
*.wav
*.ogg
*.webm
*.mov
*.avi
*.mkv
*.flac

# Archives & compiled artifacts
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.gz
*.bz2
*.xz
*.jar
*.war
*.ear
*.class
*.dll
*.so
*.dylib
*.exe
*.bin
*.o
*.a

# Documents
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx

# Databases
*.sqlite
*.sqlite3
*.db

# ============================================================
# OS / editor artefacts
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
*.pem
*.key

# ============================================================
# TypeScript / Vercel / misc tooling
# ============================================================
*.tsbuildinfo
next-env.d.ts
.vercel
